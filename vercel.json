{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "trailingSlash": false,
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.artistreevabeach.com" }],
      "destination": "https://artistreevabeach.com/$1",
      "statusCode": 301
    },
    {
      "source": "/case-studies/chesapeake-bay-waterfront",
      "destination": "/case-studies/chesapeake-bay-preservation-act",
      "statusCode": 301
    },
    {
      "source": "/case-study",
      "destination": "/case-studies",
      "statusCode": 301
    },
    {
      "source": "/case-studies/disease-management",
      "destination": "/case-studies/emerald-ash-borer",
      "statusCode": 301
    },
    {
      "source": "/case-studies/unlicensed-contractors",
      "destination": "/case-studies/virginia-tree-law",
      "statusCode": 301
    }
  ],
  "rewrites": [
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/admin/:path*", "destination": "/index.html" },
    { "source": "/login", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ]
}
