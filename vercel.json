{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.artistreevabeach.com" }],
      "destination": "https://artistreevabeach.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/((?!assets/|.*\\..*).*)", "destination": "/index.html" }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
