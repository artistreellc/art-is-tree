{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.artistreevabeach.com" }],
      "destination": "https://artistreevabeach.com/$1",
      "permanent": true
    },
    {
      "source": "/case-studies/chesapeake-bay-waterfront",
      "destination": "/case-studies/chesapeake-bay-preservation-act",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
